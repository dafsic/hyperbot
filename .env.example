# Copy to `.env` and fill in. Used by docker-compose and the bot.

# --- Hyperliquid API wallet ---
# Private key of the API wallet (hex). NEVER commit the real value.
HYPERBOT_PRIVATE_KEY=0xyour_api_wallet_private_key

# Optional: override the network configured in config.toml (mainnet|testnet).
HYPERBOT_NETWORK=testnet

# --- Database ---
# Credentials used by the bundled PostgreSQL container.
POSTGRES_USER=hyperbot
POSTGRES_PASSWORD=change_me
POSTGRES_DB=hyperbot

# Connection string the bot uses. Host "postgres" matches the compose service.
DATABASE_URL=******postgres:5432/hyperbot

# --- Logging ---
RUST_LOG=info
